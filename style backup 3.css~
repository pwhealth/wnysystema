/*codes for tabs*/ 
      .tabs input[type=radio] {
          position: absolute;
          top: -9999px;
          left: -9999px;
      }
      .tabs {
        width: 900px;
        float: none;
        list-style: none;
        position: relative;
        padding: 0;
        margin: 0 auto;
      }
      .tabs li{
        float: left;
      }
      .tabs label {
          display: block;
          padding: 10px 20px;
          border-radius: 10px 10px 0 0;
          box-shadow: 0 3px 3px rgba(0, 0, 0, 0.4), inset 0 1px 0 #FFF;
          color: #5E5E5E;     
          font-size: 20px;
          font-weight: normal;
          font-family: sans-serif;
          background: #D1CB97;
          cursor: pointer;
          position: relative;
          top: 5px;
          -webkit-transition: all 0.2s ease-in-out;
          -moz-transition: all 0.2s ease-in-out;
          -o-transition: all 0.2s ease-in-out;
          transition: all 0.2s ease-in-out;
      }
      .tabs label:hover {
        background: #D1CB97;
        top: 0;
      }
       
      [id^=tab]:checked + label {
        background: #EAE4AD;
        color: black;
        top: 0;
      }
       
      [id^=tab]:checked ~ [id^=tab-content] {
          display: block;
      }
      .tab-content{
        z-index: 2;
        display: none;
        text-align: left;
        width: 100%;
        font-size: 1em;
        font-family: trebuchet, sans-serif;
        line-height: 140%;
        background: #EAE4AD;
        padding: 15px;
        color: black;
        position: absolute;
        top: 37px;
        left: 0;
        box-sizing: border-box;
        -webkit-animation-duration: 0.5s;
        -o-animation-duration: 0.5s;
        -moz-animation-duration: 0.5s;
        animation-duration: 0.5s;
      }
/*END codes for tabs*/

/*codes for pastevents*/

#pastevents {
    height: auto; 
    width: 100%;
    margin: 0 auto 0 auto;  
    text-align: center;  
}

#pastevents .box {
	display: inline-block;
	position: relative;
	float: left;
	width:100px; 
	height:100px;
	margin: 5px;
	overflow:hidden;
}

#pastevents .box img{
	position: absolute;
	width:100px; 
	height:100px;
	left:0;
}

#pastevents .box .caption {  
        background-color: white; 
        opacity: 0;
        position: absolute;  
        color: black;  
        z-index: 100;  
        -webkit-transition: all 300ms ease-in-out;  
        -moz-transition: all 300ms ease-in-out;  
        -o-transition: all 300ms ease-in-out;  
        -ms-transition: all 300ms ease-in-out;  
        transition: all 300ms ease-in-out;   
        width: 100px;  
        height: 100px;
        top: 0px;
        left: 0px;  
        text-align: center; 
        line-height: 100px;
           
    } 
    
#pastevents .box .caption p {
font-family: trebuchet, sans-serif;
font-size: 0.75em;
line-height: 1.8em;
display: inline-block;vertical-align: middle;
}
    
#pastevents .box:hover .caption { 
-webkit-opacity: 0.8;
-moz-opacity: 0.8;
opacity: 0.8; 
        /*-moz-transform: translateY(100%);  
        -o-transform: translateY(100%);  
        -webkit-transform: translateY(100%);  
        transform: translateY(100%);  */
    }    
/*END codes for pastevents*/

